
# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# NCP Clova Studio API (Optional - for LLM features)
# Get from: https://www.ncloud.com/
NCP_API_KEY=
NCP_CLOVASTUDIO_ENDPOINT=

DATABASE_URL=
NAVER_API_KEY=

# AI Gateway
APP_PORT=8100
AI_GATEWAY_REQUIRE_AUTH=true
AI_GATEWAY_LOG_LEVEL=INFO
AI_GATEWAY_HTTP_TIMEOUT_SECONDS=20
AI_GATEWAY_MAX_RETRIES=1
AI_GATEWAY_RETRY_BACKOFF_SECONDS=0.5
AI_GATEWAY_MAX_AUDIO_BYTES=6000000
AI_GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,https://kiddymate.com,https://kiddymate.vercel.app,https://kiddymate.netlify.app
AI_GATEWAY_ALLOWED_ORIGIN_REGEX=^https://(kiddymate(?:-[a-z0-9-]+)?(?:-bonxoms-projects)?\\.vercel\\.app|(?:[a-z0-9-]+--)?kiddymate\\.netlify\\.app)$
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=4000
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_STT_LANGUAGE_CODE=vi-VN
GOOGLE_TTS_VOICE_NAME=vi-VN-Standard-A
GOOGLE_TTS_LANGUAGE_CODE=vi-VN
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0
